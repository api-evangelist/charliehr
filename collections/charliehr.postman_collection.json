            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/team_members/:id/leave_requests",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "team_members",
                ":id",
                "leave_requests"
              ],
              "variable": [
                {
                  "key": "id",
                  "value": "",
                  "description": "The unique identifier of the team member."
                }
              ]
            },
            "description": "Returns the leave requests for a specific team member."
          },
          "response": []
        }
      ]
    },
