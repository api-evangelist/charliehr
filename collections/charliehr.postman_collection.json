              ],
              "path": [
                "team_members",
                ":id",
                "leave_allowance"
              ],
              "variable": [
                {
                  "key": "id",
                  "value": "",
                  "description": "The unique identifier of the team member."
                }
              ]
            },
            "description": "Returns the current leave allowance for the specified team member."
          },
          "response": []
        }
      ]
    },
